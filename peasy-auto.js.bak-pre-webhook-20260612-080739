  // PEASY v19.16: AI cv_label for /REGNR test-modus - utenfor elbilradar-if
  if (opts.aiCv) {
        try {
          log('CarInfo: starter for ' + bil.registration_number);
          const carInfo = await getCarInfoApi(bil.registration_number, bil.mileage || 0);
