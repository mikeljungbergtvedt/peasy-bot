  if ((h !== 12 && h !== 15) || _listeWatchSistSjekket === key) return;
  _listeWatchSistSjekket = key;

  const hhmm = String(oslo.getHours()).padStart(2,'0') + ':' + String(oslo.getMinutes()).padStart(2,'0');
  try {
    const token = await getErpToken();
    const seksjoner = [];
